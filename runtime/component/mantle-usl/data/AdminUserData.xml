<?xml version="1.0" encoding="UTF-8" ?>
<entity-facade-xml type="install">
    <!--
        Admin user: username=admin  password=admin
        SHA-1 hash of "admin" (no salt): d033e22ae348aeb5660fc2140aec35850c4da997
    -->
    <moqui.security.UserAccount userId="ADMIN_USER" username="admin" userFullName="Administrator"
            currentPassword="d033e22ae348aeb5660fc2140aec35850c4da997" passwordHashType="SHA"
            disabled="N"/>

    <!-- ADMIN group: full access to REST APIs, tools, built-in services -->
    <moqui.security.UserGroupMember userGroupId="ADMIN" userId="ADMIN_USER" fromDate="0"/>
    <!-- ADMIN_ADV group: login-as, SQL runner, groovy shell, load runner -->
    <moqui.security.UserGroupMember userGroupId="ADMIN_ADV" userId="ADMIN_USER" fromDate="0"/>

    <!-- ====== Blanket authorization for admin over everything ====== -->

    <!-- All Entities: full CRUD -->
    <moqui.security.ArtifactGroup artifactGroupId="ALL_ENTITIES" description="All Entities (full CRUD)"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="ALL_ENTITIES" artifactName=".*"
            nameIsPattern="Y" artifactTypeEnumId="AT_ENTITY" inheritAuthz="Y"/>
    <moqui.security.ArtifactAuthz artifactAuthzId="ALL_ENTITIES_ADMIN" userGroupId="ADMIN"
            artifactGroupId="ALL_ENTITIES" authzTypeEnumId="AUTHZT_ALWAYS" authzActionEnumId="AUTHZA_ALL"/>

    <!-- All Services: full access -->
    <moqui.security.ArtifactGroup artifactGroupId="ALL_SERVICES" description="All Services"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="ALL_SERVICES" artifactName=".*"
            nameIsPattern="Y" artifactTypeEnumId="AT_SERVICE" inheritAuthz="Y"/>
    <moqui.security.ArtifactAuthz artifactAuthzId="ALL_SERVICES_ADMIN" userGroupId="ADMIN"
            artifactGroupId="ALL_SERVICES" authzTypeEnumId="AUTHZT_ALWAYS" authzActionEnumId="AUTHZA_ALL"/>

    <!-- All Screens: full access -->
    <moqui.security.ArtifactGroup artifactGroupId="ALL_SCREENS_ADMIN" description="All Screens (admin)"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="ALL_SCREENS_ADMIN" artifactName=".*"
            nameIsPattern="Y" artifactTypeEnumId="AT_XML_SCREEN" inheritAuthz="Y"/>
    <moqui.security.ArtifactAuthz artifactAuthzId="ALL_SCREENS_ADMIN_AUTHZ" userGroupId="ADMIN"
            artifactGroupId="ALL_SCREENS_ADMIN" authzTypeEnumId="AUTHZT_ALWAYS" authzActionEnumId="AUTHZA_ALL"/>

    <!-- All REST API Paths: full access -->
    <moqui.security.ArtifactGroup artifactGroupId="ALL_REST_PATHS" description="All REST API Paths"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="ALL_REST_PATHS" artifactName="/.*"
            nameIsPattern="Y" artifactTypeEnumId="AT_REST_PATH" inheritAuthz="Y"/>
    <moqui.security.ArtifactAuthz artifactAuthzId="ALL_REST_PATHS_ADMIN" userGroupId="ADMIN"
            artifactGroupId="ALL_REST_PATHS" authzTypeEnumId="AUTHZT_ALWAYS" authzActionEnumId="AUTHZA_ALL"/>
</entity-facade-xml>
